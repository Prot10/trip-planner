{
  "name": "tripplanner",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n web,agent -c cyan,magenta \"vite\" \"node server/index.mjs\"",
    "dev:web": "vite",
    "agent-server": "node server/index.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "start": "npm run build && node server/index.mjs",
    "site:dev": "cd site && vite",
    "site:build": "cd site && vite build",
    "demo:build": "VITE_DEMO=1 vite build --base=/demo/ --outDir dist-site/demo --emptyOutDir"
  },
  "engines": {
    "node": ">=20.19"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.198",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "i18next": "^26.3.4",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "react-leaflet": "^5.0.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14",
    "puppeteer-core": "^25.3.0"
  },
  "devDependencies": {
    "@anthropic-ai/claude-code": "^2.1.199",
    "@openai/codex": "^0.142.5",
    "@tailwindcss/vite": "^4.3.2",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "tailwindcss": "^4.3.2",
    "vite": "^8.1.3"
  }
}
